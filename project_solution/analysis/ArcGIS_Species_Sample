#ArcGis Data

library(readxl)

arc_dc_trees <- read_excel("dc_trees.xlsx")
str(arc_dc_trees)
head(arc_dc_trees)

# Pull Species Data

library(dplyr)

dc_species_counts <- arc_dc_trees %>%
  group_by(SpCode) %>%
  summarise(total_obs = n()) %>%
  arrange(desc(total_obs))

species_lookup <- arc_dc_trees %>%
  select(SpCode, SCI_NM) %>%
  distinct()

dc_species_counts_with_scinames <- dc_species_counts %>%
  left_join(species_lookup, by = "SpCode")

dc_species_counts

dc_species_counts_with_scinames

## Top 20
top20 <- dc_species_counts %>%
  slice_max(total_obs, n = 20)


## QC Plot


library(ggplot2)

ggplot(top20, aes(x = reorder(SpCode, total_obs), y = total_obs)) +
  geom_col(fill = "steelblue") +
  coord_flip() +
  labs(title = "Top 20 Species by Observation Count",
       x = "Species Code",
       y = "Observations") +
  theme_minimal()



## Save as Excel and R Object

install.packages("writexl")
library(writexl)

write_xlsx(dc_species_counts, "arc_dc_species_counts.xlsx")
write_xlsx(top20, "arc_dc_top20_species.xlsx")


saveRDS(dc_species_counts, "dc_species_counts.rds")
saveRDS(top20, "dc_top20_species.rds")




write_xlsx(dc_species_counts_with_scinames, "arc_dc_species_counts_scinames.xlsx")

saveRDS(dc_species_counts_with_scinames, "dc_species_counts_scinames.rds")


