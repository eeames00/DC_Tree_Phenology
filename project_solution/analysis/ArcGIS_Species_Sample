###Join Datasets



setDT(arc_dc_trees)
setDT(compiled_crown_ndvi_polygon_subset)

arc_dc_trees[, UID := as.character(UID)]
compiled_crown_ndvi_polygon_subset[, UID := as.character(UID)]


tree_info <- arc_dc_trees[, .(
  UID,
  DBH,
  SCI_NM,
  SCI_mrg,
  SpCode_arc = SpCode,     # keep separate name to compare
  Genus,
  origin,
  native,
  chm_ht,
  Shape__Area
)]


## Combined Data Sets
ndvi_with_treeinfo <- merge(
  compiled_crown_ndvi_polygon_subset,
  tree_info,
  by = "UID",
  all.x = TRUE
)

#missing matches
ndvi_with_treeinfo[is.na(DBH), .N]
#percent of matches
ndvi_with_treeinfo[, mean(!is.na(DBH))] * 100


