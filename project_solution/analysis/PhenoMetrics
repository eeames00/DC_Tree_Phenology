          eos_concavity_doy <- x_interp[eos_concavity_idx]
          eos_convexity_idx <- which(ndvi_curve == min(ndvi_curve[late_season_idx], na.rm = TRUE))
          eos_convexity_doy <- x_interp[eos_convexity_idx]
          
          # store parameter estimates -----------------------------------------------------------
          params <- mnew$m$getPars()
          df_params_this_iter <- data.frame(
            "m1" = params[[1]], "m2" = params[[2]], "m3" = params[[3]], "m4" = params[[4]],
            "m5" = params[[5]], "m6" = params[[6]], "m7" = params[[7]], sos_concavity_doy,
            sos_convexity_doy, eos_convexity_doy, eos_concavity_doy, g15_spl, g50_spl, g90_spl,
            b10_spl, b50_spl, b85_spl
          )
          df_params <- rbind(df_params, df_params_this_iter)
          
          # predict using doy 1 to doy 365
