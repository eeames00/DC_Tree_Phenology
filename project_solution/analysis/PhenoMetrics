          b10_spl <- spl_metrics$b10
          b50_spl <- spl_metrics$b50
          b85_spl <- spl_metrics$b85
          
          # DL fit stuff ------------------------------------------------------------------------------
          mnew <- nlsLM(
            y ~ a + (b - g * x) * ((1 / (1 + exp((c - x) / d))) - (1 / (1 + exp((e - x) / f)))),
            start = list(
              a = mnew3_params[1], b = mnew3_params[2], c = mnew3_params[3], d = mnew3_params[4],
              e = mnew3_params[5], f = mnew3_params[6], g = mnew3_params[7]
            ),
            weights = w
          )
          
          # calculate concavity based on 2nd derivative of interpolated function
          x_interp <- seq(min(x), max(x), 0.1)
          ndvi_interp <- v(mnew$m$getPars(), x_interp)
          ndvi_curve <- diff(diff(ndvi_interp))
