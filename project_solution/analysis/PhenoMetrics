          pred_mat_365[, j] <- v(as.numeric(df_params_this_iter[1, 1:7]), new_x0)
          pred_mat_spl_365[, j] <- predict(sm_spline, new_x0)$y
          
        }, silent = TRUE)
        
      } # end bootstrap loop
      
      if (nrow(df_params) == 0) {
        stop("No successful bootstrap iterations")
      }
      
      # summary of all parameters for this crown
      param_summary <- describe(df_params)
      m_med <- param_summary$median
