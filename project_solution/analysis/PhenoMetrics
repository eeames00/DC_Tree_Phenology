        boot_idx <- sample(seq(1, length(x)), replace = TRUE)
        x <- x[boot_idx]
        y <- y[boot_idx]
        w <- w[boot_idx]
        
        try({
          
          # spl stuff --------------------------------------------
          x_dith <- dither(x)
