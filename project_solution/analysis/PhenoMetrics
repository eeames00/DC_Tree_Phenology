results_list <- foreach(
  i = iter_subset,
  .packages = c("ggplot2", "data.table", "psych", "matrixStats",
                "minpack.lm", "quantreg", "splines", "dplyr", "caTools")
) %dopar% {
  
  # start trycatch. Nested result. Must return to result_tc and then return that to foreach
  result_tc <- tryCatch(
    expr = {
      
      # make function available in the loop in case that's important to parallel worker scope
      v <- function(m, t) {
        m[1] + (m[2] - m[7] * t) *
          ((1 / (1 + exp((m[3] - t) / m[4]))) - (1 / (1 + exp((m[5] - t) / m[6]))))
