      # if there are date dupes, keep the record with highest absolute NDVI
      tree_dat <- tree_dat[order(tree_dat$im_date, -abs(tree_dat$ndvi)), ]
      dup_bin <- duplicated(tree_dat$im_date)
      tree_dat <- tree_dat[!dup_bin, ]
      
